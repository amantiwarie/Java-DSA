class NumberTask implements Runnable {
    public void run() {
        for(int i = 1; i <= 5; i++) {
            System.out.println(Thread.currentThread().getName() + " -> " + i);
        }
    }
}

public class basic {
    public static void main(String[] args) {
        Thread t1 = new Thread(new NumberTask());
        Thread t2 = new Thread(new NumberTask());

        t1.start();
        t2.start();
    }
}
